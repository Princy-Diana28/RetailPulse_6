# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Streamlit
.streamlit/secrets.toml

# Data & model artifacts (regenerated by the pipeline / kept out of version control by default)
data/processed/*.parquet
saved_models/*.joblib
outputs/reports/*

# Keep folder structure without committing generated artifacts
!data/processed/.gitkeep
!saved_models/.gitkeep
!outputs/reports/.gitkeep

# OS / editor
.DS_Store
.idea/
.vscode/
*.log

# Jupyter
.ipynb_checkpoints/
